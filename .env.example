# Copier en `.env` (gitignored) pour le développement local.
# En prod (Vercel) : configurer dans Settings → Environment Variables.

# URL du backend Django REST API
VITE_API_URL=https://websig-api.josuelassey.pro

# URL WMS du GeoServer (chemin /wms du workspace)
VITE_GEOSERVER_URL=https://websig-geo.josuelassey.pro/geoserver/geoportail/wms

# Couche par défaut affichée sur la carte (workspace:layer)
VITE_GEOSERVER_LAYER=geoportail:parcelles_ag1
